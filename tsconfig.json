{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "allowJs": true
  },
  "include": [
    "scripts/**/*.mjs",
    "scripts/**/*.js",
    "scripts/**/*.cjs",
    "*.md"
  ],
  "exclude": [
    "node_modules",
    "v1",
    "apps",
    "services",
    "packages",
    "infra",
    "coverage",
    "playwright-report",
    "test-results",
    "log"
  ]
}
