{
  "chain": [
    {
      "name": "primary",
      "provider": "vllm-node-a",
      "model": "qwen3.5-32b",
      "timeout_seconds": 30,
      "enabled": true,
      "allowed_classifications": ["public", "internal", "confidential", "restricted"],
      "base_url": "${VLLM_NODE_A_URL}",
      "api_key": "${VLLM_NODE_A_API_KEY}"
    },
    {
      "name": "secondary",
      "provider": "vllm-node-b",
      "model": "qwen3.5-32b",
      "timeout_seconds": 30,
      "enabled": true,
      "allowed_classifications": ["public", "internal", "confidential", "restricted"],
      "base_url": "${VLLM_NODE_B_URL}",
      "api_key": "${VLLM_NODE_B_API_KEY}"
    },
    {
      "name": "lightweight",
      "provider": "vllm-node-a",
      "model": "qwen3.5-7b",
      "timeout_seconds": 15,
      "enabled": true,
      "allowed_classifications": ["public", "internal", "confidential", "restricted"],
      "base_url": "${VLLM_NODE_A_URL}",
      "api_key": "${VLLM_NODE_A_API_KEY}"
    },
    {
      "name": "last_resort",
      "provider": "openrouter",
      "model": "qwen/qwen-2.5-72b-instruct",
      "timeout_seconds": 60,
      "enabled": true,
      "allowed_classifications": ["public", "internal", "confidential"],
      "base_url": "${OPENROUTER_BASE_URL}",
      "api_key": "${OPENROUTER_API_KEY}"
    }
  ]
}
