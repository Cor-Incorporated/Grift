{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://benevolentdirector.app/events/ProjectOutcomeRecorded.json",
  "title": "ProjectOutcomeRecorded",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "ProjectOutcomeRecorded"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "case_id": {
              "type": "string",
              "format": "uuid"
            },
            "estimate_id": {
              "type": [
                "string",
                "null"
              ],
              "format": "uuid"
            },
            "actual_hours": {
              "type": "number"
            },
            "actual_cost": {
              "type": [
                "number",
                "null"
              ]
            },
            "deviation_percent": {
              "type": [
                "number",
                "null"
              ]
            },
            "notes": {
              "type": [
                "string",
                "null"
              ]
            },
            "completed_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            },
            "updated_at": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "id",
            "case_id",
            "actual_hours",
            "created_at",
            "updated_at"
          ]
        }
      },
      "required": [
        "payload"
      ]
    }
  ]
}
