{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://benevolentdirector.app/events/ApprovalDecisionMade.json",
  "title": "ApprovalDecisionMade",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "ApprovalDecisionMade"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "proposal_id": {
              "type": "string",
              "format": "uuid"
            },
            "decision": {
              "enum": [
                "approved",
                "rejected"
              ]
            },
            "decided_by_uid": {
              "type": "string",
              "minLength": 1
            },
            "decided_by_role": {
              "type": [
                "string",
                "null"
              ]
            },
            "comment": {
              "type": [
                "string",
                "null"
              ]
            },
            "decided_at": {
              "type": "string",
              "format": "date-time"
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "id",
            "proposal_id",
            "decision",
            "decided_by_uid",
            "decided_at",
            "created_at"
          ]
        }
      },
      "required": [
        "payload"
      ]
    }
  ]
}
