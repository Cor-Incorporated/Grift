{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://benevolentdirector.app/events/RequirementArtifactGenerated.json",
  "title": "RequirementArtifactGenerated",
  "allOf": [
    {
      "$ref": "./_envelope.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "RequirementArtifactGenerated"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "case_id": {
              "type": "string",
              "format": "uuid"
            },
            "version": {
              "type": "integer",
              "minimum": 1
            },
            "markdown": {
              "type": "string"
            },
            "source_chunks": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              }
            },
            "status": {
              "enum": [
                "draft",
                "finalized"
              ]
            },
            "created_by_uid": {
              "type": [
                "string",
                "null"
              ]
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            },
            "updated_at": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "id",
            "case_id",
            "version",
            "markdown",
            "source_chunks",
            "status",
            "created_at",
            "updated_at"
          ]
        }
      },
      "required": [
        "payload"
      ]
    }
  ]
}
