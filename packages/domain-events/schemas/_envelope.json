{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://benevolentdirector.app/events/_envelope.json",
  "title": "DomainEventEnvelope",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid"
    },
    "aggregate_type": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_id": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_version": {
      "type": "integer",
      "minimum": 0
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "source_domain": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "deprecated": true,
      "description": "Legacy alias. Use occurred_at."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "deprecated": true,
      "description": "Legacy semver event version. Use aggregate_version."
    },
    "payload": {}
  },
  "required": [
    "event_id",
    "event_type",
    "tenant_id",
    "aggregate_type",
    "aggregate_id",
    "aggregate_version",
    "occurred_at",
    "idempotency_key",
    "producer",
    "source_domain",
    "payload"
  ]
}
